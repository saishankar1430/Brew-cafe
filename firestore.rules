rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is authenticated (Admin)
    function isAdmin() {
      return request.auth != null;
    }

    // Reservations rules
    match /reservations/{id} {
      allow create: if true;
      allow read: if true;
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['emailSent', 'emailSentAt', 'confirmationEmailBody', 'status']) || isAdmin();
      allow delete: if isAdmin();
    }

    // Orders rules
    match /orders/{id} {
      allow create: if true;
      allow read: if true; // clients can check status, or admins
      allow update, delete: if isAdmin();
    }

    // Reviews rules
    match /reviews/{id} {
      allow read: if true; // clients can see approved, admins can see all
      allow create: if true; // guests can submit reviews
      allow update, delete: if isAdmin();
    }

    // Menu rules
    match /menu/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
